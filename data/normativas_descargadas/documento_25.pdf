    <script>
        var translationsToEnglish = {
            "Descárgala para:": "Download it to:",
            "Conocer tu permanencia autorizada": "Know your authorized stay",
            "Acreditar tu ingreso regular al Perú": "Provide your regular entry to Peru",
            "Otros fines en los que sea solicitada": "Other purposes for which it is requested",
            "Recomendaciones:": "Recommendations:",
            "Ingrese sólo números y letras (sin puntos ni guiones)": "Enter only numbers and letters (no periods or dashes)",
            "En caso de inconvenientes, reportarlo a": "In case of inconvenience, report it to",
            "Datos del solicitante": "Applicant details",
            "Tipo de documento (*)": "Document type (*)",
            "Número de documento (*)": "Document number (*)",
            "Nacionalidad (*)": "Nationality (*)",
            "Fecha de llegada o salida (*)": "Arrival or departure date (*)",
            "TAM Virtual de Salida": "Virtual Output TAM",
            "Ingresar caracteres (*)": "Enter characters (*)",
            "Verificar": "Check",
            "Limpiar": "Clear",
            "(*) Campos obligatorios": "(*) Required fields",
            "Resultados de búsqueda": "Search results",
            "Descargar tam": "Download TAM",
            "Tarjeta Andina de Migración (TAM) Virtual": "Andean Migration Card (TAM) Virtual"
        };

        var translationsToSpanish = {
            "Download it to:": "Descárgala para:",
            "Know your authorized stay": "Conocer tu permanencia autorizada",
            "Provide your regular entry to Peru": "Acreditar tu ingreso regular al Perú",
            "Other purposes for which it is requested": "Otros fines en los que sea solicitada",
            "Recommendations:": "Recomendaciones:",
            "Enter only numbers and letters (no periods or dashes)": "Ingrese sólo números y letras (sin puntos ni guiones)",
            "In case of inconvenience, report it to": "En caso de inconvenientes, reportarlo a",
            "Applicant details": "Datos del solicitante",
            "Document type (*)": "Tipo de documento (*)",
            "Document number (*)": "Número de documento (*)",
            "Nationality (*)": "Nacionalidad (*)",
            "Arrival or departure date (*)": "Fecha de llegada o salida (*)",
            "Virtual Output TAM": "TAM Virtual de Salida",
            "Enter characters (*)": "Ingresar caracteres (*)",
            "Check": "Verificar",
            "Clear": "Limpiar",
            "(*) Required fields": "(*) Campos obligatorios",
            "Search results": "Resultados de búsqueda",
            "Download TAM": "Descargar tam",
            "Andean Migration Card (TAM) Virtual": "Tarjeta Andina de Migración (TAM) Virtual"
        };

        function translateText(language) {
            var translations = (language === 'english') ? translationsToEnglish : translationsToSpanish;

            // Seleccionar todos los elementos con la clase 'translation'
            var elements = document.querySelectorAll('.translation');

            elements.forEach(function (element) {
                var text = element.innerText.trim(); // Obtener el texto sin espacios adicionales

                // Intentar obtener la traducción exacta
                if (translations[text]) {
                    element.innerText = translations[text];
                } else {
                    // Intentar capitalizar la primera letra y buscar nuevamente
                    var capitalizedText = text.charAt(0).toUpperCase() + text.slice(1).toLowerCase();
                    if (translations[capitalizedText]) {
                        element.innerText = translations[capitalizedText];
                    } else {
                        // Convertir el texto a minúsculas para búsqueda inicial
                        var lowerCaseText = text.toLowerCase();
                        if (translations[lowerCaseText]) {
                            element.innerText = translations[lowerCaseText];
                        } else {
                            // Si no se encuentra ninguna traducción, mantener el texto original
                            console.log('No se encontró traducción para: ' + text);
                        }
                    }
                }
            });



            //traducir botones
            var cboTipoDocumento = document.querySelector('[id$="cboTipoDocumento1"]');
            if (cboTipoDocumento) {
                var options = cboTipoDocumento.options;
                    var optionText = options[0].textContent.trim();
                    if (translations[optionText]) {
                        options[0].textContent = translations[optionText];
                    }
                
            }
            var cboPais_ = document.querySelector('[id$="cboPais"]');
            if (cboPais_) {
                var options = cboPais_.options;
                    var optionText = options[0].textContent.trim();
                    if (translations[optionText]) {
                        options[0].textContent = translations[optionText];
                    }
                
            }

                //placeholder
                var inputNumeroDoc = document.querySelector('[id$="txtNumeroDoc"]');
                if (inputNumeroDoc) {
                    var placeholderText = inputNumeroDoc.getAttribute('placeholder').trim();
                    if (translations[placeholderText]) {
                        inputNumeroDoc.setAttribute('placeholder', translations[placeholderText]);
                    }
                }

                var inputFechaLLegada = document.querySelector('[id$="txtFechaViaje"]');
                if (inputFechaLLegada) {
                    var placeholderText = inputFechaLLegada.getAttribute('placeholder').trim();
                    if (translations[placeholderText]) {
                        inputFechaLLegada.setAttribute('placeholder', translations[placeholderText]);
                    }
                }

                var inputValidator = document.querySelector('[id$="txtvalidator"]');
                if (inputValidator) {
                    var placeholderText = inputValidator.getAttribute('placeholder').trim();
                    if (translations[placeholderText]) {
                        inputValidator.setAttribute('placeholder', translations[placeholderText]);
                    }
                }

                var labelElement = document.querySelector('label[for="ctl00_bodypage_chkSalida"]');
                if (labelElement) {
                    var labelText = labelElement.textContent.trim();
                    if (translations[labelText]) {
                        labelElement.textContent = translations[labelText];
                    }
                }


//                var h1Element = document.querySelector('.translation');
//                if (h1Element) {
//                    var text = h1Element.textContent.trim();
//                    if (translations[text]) {
//                        h1Element.textContent = translations[text];
//                    }
//                }

            // Traducir el texto de los botones si están presentes
            var verifyButton = document.querySelector('[id$="btnVerificar"]');
            var clearButton = document.querySelector('[id$="btnLimpiar"]');

            if (verifyButton) {
                var verifyButtonText = verifyButton.getAttribute('value').trim();
                if (translations[verifyButtonText]) {
                    verifyButton.setAttribute('value', translations[verifyButtonText]);
                }
            }

            if (clearButton) {
                var clearButtonText = clearButton.getAttribute('value').trim();
                if (translations[clearButtonText]) {
                    clearButton.setAttribute('value', translations[clearButtonText]);
                }
            }
        }

        function toggleLanguage() {
            var currentLanguage = document.documentElement.lang;
            var newLanguage = (currentLanguage === 'en') ? 'es' : 'en';
            document.documentElement.lang = newLanguage;


            // Cambiar el texto del enlace
            var link = document.getElementById('languageToggle');
            link.innerText = (newLanguage === 'en') ? 'Disponible en español' : 'Disponible en inglés';

            translateText(newLanguage === 'en' ? 'english' : 'spanish');
        }
    </script>
        
