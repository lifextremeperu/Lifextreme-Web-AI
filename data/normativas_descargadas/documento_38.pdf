<script>

    var urlWhatsApp = "https://api.whatsapp.com/send?phone=51980901074&amp;text=&#161;Hola%20Turismo%20In!%20Quisiera%20obtener%20m&#225;s%20informaci&#243;n.";

    window.addEventListener('load', function () {
        $(".nav-submenu-click .Reportes").parent().click(LimpiarLocalStorageReportes);
        //$("#2-tab").hide();
        $("#btnWhatsAppHome").on("click", () => {
            window.open(urlWhatsApp, '_blank');
        });
    });

    function LimpiarLocalStorageReportes(){
        localStorage.removeItem("anio");
        localStorage.removeItem("aniob");
        localStorage.removeItem("active");
        localStorage.removeItem("category");
    }






</script>
