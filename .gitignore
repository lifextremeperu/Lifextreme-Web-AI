# ============================================================
# .gitignore OPTIMIZADO — Lifextreme Web AI
# Actualizado: 2026-06-26 | Objetivo: evitar cuelgues del IDE
# ============================================================

# ── NETLIFY ─────────────────────────────────────────────────
.netlify

# ── PYTHON — Caché y compilados ─────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.benchmarks/
.mypy_cache/
.ruff_cache/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
pytest.ini
pytest-cache/

# ── NODE.JS ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm
.yarn-integrity
*.tsbuildinfo

# ── IDEs ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── VARIABLES DE ENTORNO Y CREDENCIALES ─────────────────────
.env
.env.local
.env.*.local
service_account.json
gcp-ai-key.json

# ── LOGS ─────────────────────────────────────────────────────
logs/
*.log
logs_ingesta*.txt
output.txt

# ── SISTEMA OPERATIVO ────────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini

# ── ARCHIVOS TEMPORALES ──────────────────────────────────────
*.tmp
*.temp
tmp/
scratch/
.cache/
*.gstmp

# ── BUILD OUTPUTS ────────────────────────────────────────────
dist/
build/
*.min.js
*.min.css
*.map

# ── DEPLOY ───────────────────────────────────────────────────
.vercel
.firebase/
.firebaserc

# ── VECTOR DATABASE (ChromaDB) — MUY PESADO ─────────────────
# 172 MB — No necesita estar en git ni indexado por el IDE
chroma_db/

# ── KNOWLEDGE BASE / DATOS MASIVOS ──────────────────────────
# 4.5 GB de PDFs + JSONs masivos — Solo necesitas el código
data/raw_pdfs/
data/knowledge/
data/_control/
data/social/
data/news/
data/guides/
data/blog/

# Archivos JSONL grandes de conocimiento
*.jsonl

# CSV masivo de FAQs (1.7 MB — innecesario en git)
tours_faq.csv

# ── BACKUPS Y ZIPS ───────────────────────────────────────────
*.zip
Lifextreme_AI_Respaldo_*.zip

# ── ARCHIVOS DE ESTADO DE INGESTA ───────────────────────────
ingestion_state.json
revectorize_checkpoint.json

# ── IMÁGENES PESADAS (HEIC / archivos locales) ───────────────
*.HEIC
*.heic

# ── SOURCE MAPS DE NODE (543 archivos = 13.8 MB inútiles) ────
**/*.js.map
**/*.css.map

*.parquet
*.jsonl
