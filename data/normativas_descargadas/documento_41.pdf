<!-- ALTIMEA CONSENT BANNER (auto) -->
<div id="consent-root" class="cb-hidden" data-consent-root>

  <!-- Banner inicial (non-modal, fixed bottom). Sin role=dialog: es una banda
       informativa con CTAs, no un dialog modal. aria-labelledby permite que el
       lector de pantalla anuncie el contenido al recibir foco programatico. -->
  <section id="cb-banner"
           class="cb-banner cb-hidden"
           aria-labelledby="cb-banner-body"
           data-cb-banner>
    <div class="cb-banner-inner">
      <p id="cb-banner-body" class="cb-banner-body">
        <strong>Usamos cookies.</strong> Las necesarias garantizan el funcionamiento del sitio; analítica y marketing requieren tu consentimiento. <a href="/privacidad/">Política de privacidad</a>.
      </p>
      <div class="cb-banner-actions">
        <button type="button" class="cb-btn cb-btn-text" data-cb-action="reject-all">Rechazar</button>
        <button type="button" class="cb-btn cb-btn-ghost" data-cb-action="open-settings">Configurar</button>
        <button type="button" class="cb-btn cb-btn-primary" data-cb-action="accept-all">Aceptar todas</button>
      </div>
    </div>
  </section>

  <!-- Modal granular (overlay con backdrop) -->
  <div id="cb-modal-backdrop"
       class="cb-modal-backdrop cb-hidden"
       data-cb-modal-backdrop
       hidden></div>

  <section id="cb-modal"
           class="cb-modal cb-hidden"
           role="dialog"
           aria-modal="true"
           aria-labelledby="cb-modal-title"
           data-cb-modal
           hidden>
    <header class="cb-modal-header">
      <h2 id="cb-modal-title" class="cb-modal-title">Configurar cookies</h2>
      <button type="button"
              class="cb-modal-close"
              aria-label="Cerrar configuración de cookies"
              data-cb-action="close-settings">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="18" y1="6" x2="6" y2="18"></line>
        </svg>
      </button>
    </header>

    <div class="cb-modal-body">

      <!-- Necesarias (always granted) -->
      <article class="cb-category">
        <header class="cb-category-header">
          <h3 class="cb-category-title">Necesarias</h3>
          <span class="cb-category-status cb-category-status-locked">Siempre activas</span>
        </header>
        <p class="cb-category-desc">
          Garantizan el funcionamiento del sitio (sesión, preferencias técnicas, seguridad).
          No se pueden desactivar.
        </p>
      </article>

      <!-- Analítica -->
      <article class="cb-category">
        <header class="cb-category-header">
          <h3 class="cb-category-title" id="cb-cat-analytics-label">Analítica</h3>
          <button type="button"
                  class="cb-toggle"
                  role="switch"
                  aria-checked="false"
                  aria-labelledby="cb-cat-analytics-label"
                  aria-label="Activar cookies de analítica"
                  data-cb-toggle="analytics">
            <span class="cb-toggle-track" aria-hidden="true">
              <span class="cb-toggle-thumb"></span>
            </span>
          </button>
        </header>
        <p class="cb-category-desc">
          Nos ayudan a entender cómo se usa el sitio (páginas más visitadas, recorrido, tiempos)
          para mejorarlo. Ej: Google Analytics, Microsoft Clarity.
        </p>
      </article>

      <!-- Marketing -->
      <article class="cb-category">
        <header class="cb-category-header">
          <h3 class="cb-category-title" id="cb-cat-marketing-label">Marketing</h3>
          <button type="button"
                  class="cb-toggle"
                  role="switch"
                  aria-checked="false"
                  aria-labelledby="cb-cat-marketing-label"
                  aria-label="Activar cookies de marketing"
                  data-cb-toggle="marketing">
            <span class="cb-toggle-track" aria-hidden="true">
              <span class="cb-toggle-thumb"></span>
            </span>
          </button>
        </header>
        <p class="cb-category-desc">
          Permiten medir y mostrar anuncios relevantes en otras plataformas.
          Ej: Meta (Facebook/Instagram), LinkedIn.
        </p>
      </article>

    </div>

    <footer class="cb-modal-actions">
      <button type="button" class="cb-btn cb-btn-text" data-cb-action="reject-all">Rechazar todas</button>
      <button type="button" class="cb-btn cb-btn-primary" data-cb-action="save-custom">Guardar elección</button>
    </footer>
  </section>

</div>
