    <!-- Script Canonical-->
    <script>

        $(() => {
            $("#hdUrlActual").val(location.href);
        });

        var urlcanonical = window.location.href;
        var url404cn = window.location.href.split('/')[4];

        if (url404cn == '404') {
        }
        else {
            $('head').append('<link id="canonico_url" hreflang="es-PE" rel="canonical" />');
            document.getElementById("canonico_url").setAttribute("href", urlcanonical);
            $('head').append('<link id="canonico_alt" hreflang="es-PE" rel="alternate" />');
            document.getElementById("canonico_alt").setAttribute("href", urlcanonical);
        }

        

    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var hash = window.location.hash.toLowerCase().trim();
            if (hash.indexOf("?") > -1) {
                hash = hash.split('?')[0];
            }
            switch (hash) {
                case '#registro':
                    var registrateButton = document.querySelector('.login .registrate');
                    if (registrateButton) { registrateButton.click(); }
                    break;
                case '#login':
                    var loginButton = document.querySelector('.logeate');
                    if (loginButton) { loginButton.click(); }
                    break;
                default:
            }
        });
    </script>
