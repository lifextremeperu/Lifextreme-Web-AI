          <div>
    <link rel="stylesheet" href="Docs/spa/Interface/mmarquer/css/style.css">

    <div id="app-marquer">
      <template v-if="loaded">
        <template v-if="!error">
          <template v-if="noticias.length>0">
            <div>
              <div class="marquee-content">
                  <template v-for="noticia in noticias">
                    <a
                      :href="noticia.post_link">
                      {{noticia.post_title}}
                    </a>
                  </template>
              </div>

            </div>
                </template>
              </template>
        </template>
    </div>

    <div class="clearfix"></div>

    <script src="Docs/spa/Interface/mmarquer/js/main.js"></script>
    <script src="Docs/spa/Interface/mmarquer/js/jquery.marquee.min.js"></script>
  
<!--INC1[/Docs/0/Interface/mmarquer/index.html]--></div>
