            <div class="groupnews">
              <div class="visScroll groupnews-section agenda" data-wrap="true">
                <h2 class=''>Destacados</h2>
<ul class='listaNoticias '>
<li class='item idx1 section1 first pdf'>
	<a href='/Storage/modsnw/pdf/15885-Ar4Dz4Ev3Iw3Bi9.pdf'  target='_blank'>
		<span class='image' style="background-image:url()"></span>
		<span class='section'>Destacados</span>
