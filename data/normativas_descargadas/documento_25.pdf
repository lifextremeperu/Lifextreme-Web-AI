    <script type="text/javascript">
    function handleBackspace(input, event) {
        // Detectar la tecla de retroceso
        if (event.keyCode === 8) {
            // Obtener la posición del cursor
            let cursorPosition = input.selectionStart;

            // Si el cursor está en la posición de un '/', mover el cursor hacia atrás
            if (cursorPosition === 3 || cursorPosition === 6) {
                input.setSelectionRange(cursorPosition - 1, cursorPosition - 1);
                event.preventDefault(); // Prevenir la acción predeterminada de borrar
            }
        }
    }

    function formatInput(input) {
        // Guardar la posición del cursor
        let cursorPosition = input.selectionStart;
        let value = input.value;

        // Permitir solo números y "/"
        value = value.replace(/[^\d]/g, '');

        // Guardar la longitud antes del formateo
        let lengthBefore = value.length;

        // Formatear como dd/MM/yyyy
        if (value.length > 2) {
            value = value.slice(0, 2) + '/' + value.slice(2);
        }
        if (value.length > 5) {
            value = value.slice(0, 5) + '/' + value.slice(5);
        }

        // Limitar la longitud a 10 caracteres (dd/MM/yyyy)
        if (value.length > 10) {
            value = value.slice(0, 10);
        }

        // Establecer el valor formateado en el campo de texto
        input.value = value;

        // Ajustar la posición del cursor después de la inserción del '/'
        if (lengthBefore < value.length && (cursorPosition === 3 || cursorPosition === 6)) {
            cursorPosition++;
        } else if (lengthBefore > value.length && (cursorPosition === 4 || cursorPosition === 4)) {
            cursorPosition--;
        }

        // Restaurar la posición del cursor
        input.setSelectionRange(cursorPosition, cursorPosition);
    }
    </script>
</head>
