    <div id="app-noticia" class="modSmallNews articlesList Home Section4">
      <!--TITLE-->
      <div class="Title">Noticias</div>
      <!--/TITLE-->
      <div class="Items">
        <div class="SectionGroup First">
          <div class="Section">Noticias</div>

          <template v-if="loaded">
            <template v-if="error">
              <div class="alert alert-danger">
                Estamos teniendo problemas para mostrar esta sección.
              </div>
            </template>
            <template v-else>
              <template v-if="noticias.length>0">
                <template v-for="(noticia,index) in noticias">
                  <template v-if="index == 0">
                    <cr-noti-primary :props="noticia"></cr-noti-primary>
                  </template>
                  <template v-else-if="index == 1">
                    <cr-noti-secondary :props="noticia"></cr-noti-secondary>
                  </template>
                  <template v-else>
                    <cr-noti-any :props="noticia"></cr-noti-any>
                  </template>
                </template>
              </template>
              <template v-else>
                <div class="alert alert-info">
                  No ahi noticias que mostrar
                </div>
              </template>
            </template>
          </template>
          <template v-else>
            <div class="alert alert-secondary">
              Cargando...
            </div>
          </template>
        </div>
      </div>
    </div>

