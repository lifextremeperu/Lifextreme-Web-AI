          <div class="colleft">
            <!-- WORDPRESS - destacados | 2019-11-21 | dveliz -->
            <div class="slidenews">
              
    <link
      rel="stylesheet"
      href="Interface/modSmallNews/bxSlider/bxslider/jquery.bxslider.css"
      type="text/css"
    />

    <div id="app-slider" class="slidenews">
      <template v-if="loaded">
        <template v-if="error">
          <div class="alert alert-danger">
            Estamos teniendo problemas para mostrar esta sección.
          </div>
        </template>
        <template v-else>
          <template v-if="noticias.length>0">
            <div class="snews">
              <template v-for="noticia in noticias">
                <cr-slide :props="noticia"></cr-slide>
              </template>
            </div>
          </template>
        </template>
      </template>
      <template v-else>
        <div class="alert alert-secondary">
          Cargando...
        </div>
      </template>
    </div>

    <script type="text/x-template" id="cr-slide">
      <!-- <div class="checkbox-wrapper" @click="check">
        <div :class="{ checkbox: true, checked: checked }"></div>
        <div class="title"></div>
      </div> -->

      <div class="slide">
        <div class="desc">
          <p class="title">
            <a
              :href="props.post_link"
              class="ItemTitleA"
              >{{ props.post_title }}</a
            >
          </p>
          <p>{{ props.post_content }}</p>
          <a
            :href="props.post_link"
            class="minfo"
            >Más información &raquo;</a
          >
        </div>
        <div class="image">
          <div class="cell">
            <a
            :href="props.post_link"
              ><img
                :src="props.post_image"
            /></a>
          </div>
        </div>
      </div>
    </script>

    <script src="Interface/modSmallNews/bxSlider/js/jquery.bxslider.js"></script>
    <script src="Docs/spa/Interface/mslider/js/main.js"></script>
  
<!--INC1[/Docs/0/Interface/mslider/index.html]-->
